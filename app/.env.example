APP_NAME=ML Tasks Service
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
DB_HOST=database
DB_PORT=5432
DATABASE_URL=postgresql+psycopg2://app_user:app_password@database:5432/app_db

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F
RABBITMQ_QUEUE=ml_tasks
RABBITMQ_EXCHANGE=
RABBITMQ_ROUTING_KEY=ml_tasks
RABBITMQ_DURABLE=true
RABBITMQ_CONNECTION_ATTEMPTS=30
RABBITMQ_RETRY_DELAY_SEC=2

WORKER_PREFETCH_COUNT=1
WORKER_SIMULATED_DELAY_SEC=1.0

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_TIMEOUT_SEC=180
OLLAMA_TEMPERATURE=0.1
